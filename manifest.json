{
  "manifest_version": 3,
  "name": "Start page",
  "homepage_url": "https://github.com/diegorezm/wallpapercl",
  "version": "1.0",
  "description": "A starter page built for you browser!",
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "startpage@app.com"
    }
  },
  "icons": {
    "16": "favicon-16.png",
    "48": "favicon-48.png",
    "128": "favicon-128.png"
  },
  "permissions": ["storage", "tabs"]
}
